# =============================================================================
# SVG Spawn — Environment Variables
# =============================================================================
# Copy this to .env.local for local development.
# For production, these are sourced from AWS Secrets Manager.
# =============================================================================

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_ID=gemini-2.5-pro

# --- Credits ---
MAX_CREDITS_FREE=50

# --- Database (optional — falls back to in-memory store if unset) ---
# DATABASE_URL=postgresql://svgspawn:password@localhost:5432/svgspawn

# --- Auth (requires DATABASE_URL to be set) ---
# BETTER_AUTH_SECRET=your-random-secret-here
# BETTER_AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- AWS Services (production only) ---
# AWS_REGION=us-east-1
# S3_BUCKET=svg-spawn-dev-artifacts
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/svg-spawn-dev-generation-jobs
# AWS_SECRETS_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:svg-spawn/dev/app-secrets
